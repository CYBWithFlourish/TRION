---
import '../styles/theme.css';
import '../styles/components.css';
import { NavWalletWrapper } from '../components/GlobalWrapper';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="TRION - Decentralized Trade Protocol for EVE Frontier" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | TRION</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Orbitron:wght@400;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="stars-overlay"></div>
		<header class="header-bar">
			<a href="/" class="logo">
				<img src="/trion_nb.png" alt="TRION" />
			</a>
			<nav class="glass-panel main-nav">
				<div class="nav-links">
					<a href="/">Orderbook</a>
					<a href="/list">New Intent</a>
					<a href="/dashboard">Dashboard</a>
				</div>
			</nav>
			<div id="wallet-btn-container">
				<NavWalletWrapper client:only="react" />
			</div>
		</header>

		<main class="container">
			<slot />
		</main>

		<footer class="container">
			<div class="footer-content">
				<p>© 2026 TRION PROTOCOL — SECURE SMART STORAGE UNIT SWAPS</p>
				<p class="text-muted">CONNECTED TO EVE UTOPIA NETWORK</p>
			</div>
		</footer>

		<style is:global>
			.stars-overlay {
				position: fixed;
				inset: 0;
				background-image: 
					radial-gradient(1.5px 1.5px at 20px 30px, #fff, rgba(0,0,0,0)),
					radial-gradient(1.5px 1.5px at 100px 100px, #fff, rgba(0,0,0,0)),
					radial-gradient(1.5px 1.5px at 150px 50px, #fff, rgba(0,0,0,0)),
					radial-gradient(1.5px 1.5px at 200px 150px, #fff, rgba(0,0,0,0));
				background-repeat: repeat;
				background-size: 250px 250px;
				opacity: 0.1;
				z-index: -1;
				pointer-events: none;
			}

			.main-nav {
				position: sticky;
				top: 1rem;
				z-index: 100;
				margin: 1rem auto;
				max-width: 1200px;
				width: calc(100% - 2rem);
				padding: 0.8rem 1.5rem;
				border-radius: 50px;
			}

			.header-bar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				max-width: 1200px;
				margin: 0 auto;
			}

			/* Logo sits left; increase visible size while constraining layout */
			.logo {
				display: block;
				/* allow larger visual footprint without breaking nav */
				max-width: 480px; /* allow wider logo */
				width: 30%;
				text-decoration: none;
			}

			/* Increase the displayed height so the logo appears larger on the page */
			.logo img { height: 96px; max-height: 120px; width: auto; object-fit: contain; display: block; }

			/* Center nav: smaller bar centered between logo and wallet */
			.main-nav { flex: 1 1 auto; display: flex; justify-content: center; align-items: center; padding: 0.4rem 1rem; }

			.nav-links { display: flex; gap: 2rem; align-items: center; }

			#wallet-btn-container { flex: 0 0 auto; }

			@media (max-width: 768px) {
				.header-bar { flex-direction: column; align-items: center; }
				.logo { width: 50%; max-width: 220px; }
				.logo img { height: 40px; }
				.main-nav { width: 100%; }
			}

			.nav-links a {
				color: var(--text-main);
				text-decoration: none;
				font-size: 0.9rem;
				font-weight: 500;
				transition: color 0.3s;
				text-transform: uppercase;
				letter-spacing: 1px;
			}

			.nav-links a:hover {
				color: var(--neon-blue);
			}

			.container {
				max-width: 1200px;
				margin: 3rem auto;
				padding: 0 1rem;
			}

			.footer-content {
				margin-top: 6rem;
				padding: 3rem 0;
				border-top: 1px solid var(--border-color);
				text-align: center;
				font-size: 0.8rem;
				letter-spacing: 1px;
			}
		</style>
	</body>
</html>
