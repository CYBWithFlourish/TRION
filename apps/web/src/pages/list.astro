---
import Layout from '../layouts/Layout.astro';
import { ListIntentPage } from '../components/ListIntentPage';
---

<Layout title="Post New Intent">
	<div class="page-header">
		<a href="/" class="back-link">← Back to Orderbook</a>
	</div>

	<ListIntentPage client:only="react" />

	<style>
		.page-header {
			margin-bottom: 2rem;
		}
		.back-link {
			color: var(--text-muted);
			text-decoration: none;
			font-size: 0.9rem;
			transition: color 0.3s;
		}
		.back-link:hover {
			color: var(--neon-blue);
		}
	</style>
</Layout>
