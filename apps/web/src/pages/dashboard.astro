---
import Layout from '../layouts/Layout.astro';
import { DashboardPage } from '../components/DashboardPage';
---

<Layout title="Dashboard">
	<div class="hero">
		<h1 class="glow-text-blue">Command Center</h1>
		<p class="text-muted">Manage your active trade intents and history.</p>
	</div>

	<DashboardPage client:only="react" />

	<style>
		.hero {
			margin-bottom: 3rem;
		}
		h1 {
			font-family: 'Orbitron', sans-serif;
			font-size: 2.5rem;
			font-weight: 800;
			margin-bottom: 0.5rem;
		}
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        .dashboard-stat {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .label {
            font-size: 0.7rem;
            color: var(--text-muted);
            letter-spacing: 2px;
        }
        .value {
            font-size: 2rem;
            font-weight: 800;
            font-family: 'Orbitron', sans-serif;
        }
        .placeholder-section {
            padding: 4rem;
            text-align: center;
        }
	</style>
</Layout>
